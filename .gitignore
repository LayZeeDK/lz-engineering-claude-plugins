# Dependencies
node_modules/

# Build output
dist/
build/
out/

# Logs
*.log
npm-debug.log*

# OS noise
.DS_Store
Thumbs.db

# Editor
.idea/
*.swp

# Session/handoff scratch (GSD resume notes) -- never distributed.
.continue-here.md

# Skill-creator eval workspaces (.claude/skills/<skill-name>-workspace/).
# Keep the eval RECORD tracked -- eval sets, eval_metadata.json, benchmark.json/.md,
# grading.json, EVAL-RESULTS.md, and the vendored tools/ harness. Ignore only caches
# and bulky raw run byproducts (produced outputs, stream transcripts, loop dumps).
# (run_loop_stderr.log is already covered by *.log above.)
.claude/skills/*-workspace/**/__pycache__/
.claude/skills/*-workspace/**/*.pyc
.claude/skills/*-workspace/**/outputs/
.claude/skills/*-workspace/**/*.stream.jsonl
.claude/skills/*-workspace/**/run_loop_stdout.json
.claude/skills/*-workspace/**/trigger-workspace/
# Generated TS modules from the FWL-04 compile harness (extract-samples.mjs) -- never committed.
.claude/skills/*-workspace/**/samples/
# Per-run eval captures: every results/ tree under the workspace holds re-runnable
# answer.md / diff.patch / meta.json byproducts (same rationale as the e2e-reference rule
# below). The verdicts live in the tracked *-RESULTS.md / *-FINDINGS.md + aggregate.json.
# results*/ also covers suffixed variants (results-v1/, results-edited/, ...); run-*/ covers
# arm-nested captures with no results/ segment (iteration-1/eval-*/{with,without}_skill/run-N/);
# trigger-results-*.json covers the after/ + baseline/ trigger-eval chunks.
.claude/skills/lz-refactor-workspace/**/results*/
.claude/skills/lz-refactor-workspace/**/run-*/
.claude/skills/lz-refactor-workspace/**/trigger-results-*.json
# Per-run eval captures for lz-red (Phase 20, Pitfall 8): the generic *-workspace rules above
# drop only caches; the bulky per-run capture dirs + probe-stdout chunks are per-skill. Mirror
# the lz-refactor block above (additive; NOT a *-workspace generalization, which would newly
# ignore already-tracked lz-tpp trigger-results-*.json).
.claude/skills/lz-red-workspace/**/results*/
.claude/skills/lz-red-workspace/**/run-*/
.claude/skills/lz-red-workspace/**/trigger-results-*.json
# EVL-01 reciprocal probe stdout + throwaway stderr (workspace root), and the runner-generated
# per-chunk eval-set inputs (recall-chunk-*.json / spec-chunk-*.json). Raw, re-runnable byproducts;
# the tracked evidence is EVAL-RESULTS.md. Root-anchored so evals/reciprocal-red.json stays tracked.
.claude/skills/lz-red-workspace/reciprocal-*.json
.claude/skills/lz-red-workspace/reciprocal-*.err
.claude/skills/lz-red-workspace/evals/d07-chunks/recall-chunk-*.json
.claude/skills/lz-red-workspace/evals/d07-chunks/spec-chunk-*.json
# Reference-eval (quick 260714-nxp): raw per-run outputs + the generated aggregate are local
# byproducts. The verdict is tracked in e2e-reference/REFERENCE-RESULTS.md; runs are re-runnable.
.claude/skills/lz-refactor-workspace/e2e-reference/results/
.claude/skills/lz-refactor-workspace/e2e-reference/aggregate.json

# Clean-room oracle: authoritative copyrighted source excerpts (Fowler/Kerievsky/GoF book
# patterns in Markdown). NEVER committed. Only the read-only oracle-reviewer subagent reads this;
# the main authoring context never does, so verbatim book prose cannot leak into the repo (DST-04).
.oracle/
.gsd-opengsd/
