# Dependencies
node_modules/

# Build output
dist/
build/
out/

# Logs
*.log
npm-debug.log*

# OS noise
.DS_Store
Thumbs.db

# Editor
.idea/
*.swp

# Session/handoff scratch (GSD resume notes) -- never distributed.
.continue-here.md

# Skill-creator eval workspaces (.claude/skills/<skill-name>-workspace/).
# Keep the eval RECORD tracked -- eval sets, eval_metadata.json, benchmark.json/.md,
# grading.json, EVAL-RESULTS.md, and the vendored tools/ harness. Ignore only caches
# and bulky raw run byproducts (produced outputs, stream transcripts, loop dumps).
# (run_loop_stderr.log is already covered by *.log above.)
.claude/skills/*-workspace/**/__pycache__/
.claude/skills/*-workspace/**/*.pyc
.claude/skills/*-workspace/**/outputs/
.claude/skills/*-workspace/**/*.stream.jsonl
.claude/skills/*-workspace/**/run_loop_stdout.json
.claude/skills/*-workspace/**/trigger-workspace/
# Generated TS modules from the FWL-04 compile harness (extract-samples.mjs) -- never committed.
.claude/skills/*-workspace/**/samples/
# Reference-eval (quick 260714-nxp): raw per-run outputs + the generated aggregate are local
# byproducts. The verdict is tracked in e2e-reference/REFERENCE-RESULTS.md; runs are re-runnable.
.claude/skills/lz-refactor-workspace/e2e-reference/results/
.claude/skills/lz-refactor-workspace/e2e-reference/aggregate.json

# Clean-room oracle: authoritative copyrighted source excerpts (Fowler/Kerievsky/GoF book
# patterns in Markdown). NEVER committed. Only the read-only oracle-reviewer subagent reads this;
# the main authoring context never does, so verbatim book prose cannot leak into the repo (DST-04).
.oracle/
